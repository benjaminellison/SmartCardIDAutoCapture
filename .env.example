# Copy this file to `.env.local` and fill in your key.
# `.env.local` is gitignored — it never gets pushed to GitHub.
# Anything prefixed VITE_ is exposed to the browser bundle, so only
# use a key that's restricted to a small set of cheap/free models.

VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=baidu/qianfan-ocr-fast:free
